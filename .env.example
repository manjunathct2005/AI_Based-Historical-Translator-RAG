# Copy this file to .env and adjust as needed.
# Nothing here is required for a basic local run -- all defaults point to
# free, open-source models and free web search.

ENV=development
DEBUG=true

# ---- LLM ----
LLM_PROVIDER=huggingface
# 0.5B by default so it fits Streamlit Community Cloud's free-tier RAM.
# Bump to Qwen/Qwen2.5-1.5B-Instruct or larger if you have more headroom
# (Docker on your own box, HF Spaces with more RAM, a paid tier, etc.)
LLM_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.3
LLM_DEVICE=auto

# ---- Embeddings ----
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL_NAME_MULTILINGUAL=BAAI/bge-m3
EMBEDDING_DIM=384

# ---- Vector store ----
VECTOR_BACKEND=faiss
VECTOR_INDEX_PATH=./data/vector_index
CHROMA_COLLECTION=historical_rag

# ---- Translation ----
TRANSLATION_MODEL_GENERAL=facebook/nllb-200-distilled-600M
TRANSLATION_MODEL_INDIC=ai4bharat/indictrans2-indic-en-1B
DEFAULT_SRC_LANG=auto
DEFAULT_TGT_LANG=eng_Latn

# ---- OCR ----
# tesseract is bundled by default for cloud deploys; switch to easyocr/both
# only if you've installed easyocr + torchvision yourself (see requirements.txt).
OCR_ENGINE=tesseract
OCR_LANGUAGES=en,hi,sa
TESSERACT_CMD=tesseract

# ---- Web retrieval ----
WEB_SEARCH_PROVIDER=duckduckgo
WEB_SEARCH_MAX_RESULTS=8
WEB_FETCH_TIMEOUT=12
WEB_FETCH_MAX_CHARS=6000
TRUSTED_DOMAINS=wikipedia.org,wikisource.org,archive.org,britannica.com,jstor.org,asi.nic.in,whc.unesco.org,sanskritdocuments.org,gretil.sub.uni-goettingen.de
ALLOW_UNTRUSTED_DOMAINS=true

# ---- Database ----
DATABASE_URL=sqlite:///./database/app.db

# ---- Health ----
HEALTHCHECK_INTERVAL_SECONDS=300

# Optional: if you want to swap in a hosted API instead of local HF models,
# add your own keys here and adjust config.py / llm/llm_engine.py accordingly.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# HUGGINGFACEHUB_API_TOKEN=
